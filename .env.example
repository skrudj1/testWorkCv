# Server
PORT=3001
NODE_ENV=development

# Почта: smtp (локально) | web3forms | sendgrid | resend (на Render Free SMTP заблокирован)
MAIL_PROVIDER=smtp

# Web3Forms — ключ встраивается в клиент при сборке (бесплатный тариф = только из браузера)
VITE_WEB3FORMS_ACCESS_KEY=xxxx-xxxx-xxxx

# SMTP — только для локальной разработки (Mailtrap, Gmail, Yandex)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_SECURE=false

# SendGrid — для production на Render (HTTPS, не SMTP)
# MAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=SG.xxx

# Resend — альтернатива SendGrid
# MAIL_PROVIDER=resend
# RESEND_API_KEY=re_xxx

# Письма с формы
MAIL_FROM="Портфолио Алексей Володько" <noreply@example.com>
MAIL_OWNER=volodko065@mail.ru

# AI — OpenRouter / DeepSeek / OpenAI (опционально)
AI_API_KEY=sk-or-...
AI_BASE_URL=https://openrouter.ai/api
AI_MODEL=openrouter/free

# CORS (для production укажите URL деплоя)
CLIENT_ORIGIN=http://localhost:5173
