{
  "name": "alexey-volodko-portfolio",
  "private": true,
  "version": "1.0.0",
  "description": "Тестовое задание: лендинг-презентация Fullstack-разработчика",
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,magenta \"npm run dev -w client\" \"npm run dev -w server\"",
    "build": "npm run build -w client && npm run build -w server",
    "build:ci": "npm ci --include=dev && npm run build",
    "start": "npm run start -w server",
    "preview": "npm run preview -w client"
  },
  "workspaces": [
    "client",
    "server"
  ],
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=18"
  }
}
